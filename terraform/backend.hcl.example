# Prefer the environment-specific backend examples under terraform/environments/.
# For example:
#   cp terraform/environments/dev.platform.backend.hcl.example terraform/environments/dev.platform.backend.hcl
# and then run:
#   ./scripts/terraform/init-platform.sh dev
bucket         = "<project-name>-<unique-suffix>-tf-state"
dynamodb_table = "<project-name>-terraform-locks"
region         = "us-east-1"
key            = "dev/platform.tfstate"
encrypt        = true
